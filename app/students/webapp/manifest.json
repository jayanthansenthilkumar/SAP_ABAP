{
    "_version": "1.65.0",
    "sap.app": {
        "id": "students",
        "type": "application",
        "title": "Student Management",
        "description": "Manage Student Records",
        "applicationVersion": {
            "version": "1.0.0"
        },
        "dataSources": {
            "mainService": {
                "uri": "/student/",
                "type": "OData",
                "settings": {
                    "odataVersion": "4.0"
                }
            }
        }
    },
    "sap.ui5": {
        "flexEnabled": true,
        "dependencies": {
            "minUI5Version": "1.120.0",
            "libs": {
                "sap.m": {},
                "sap.ui.core": {},
                "sap.fe.core": {},
                "sap.fe.macros": {},
                "sap.fe.templates": {}
            }
        },
        "models": {
            "": {
                "dataSource": "mainService",
                "preload": true,
                "settings": {
                    "synchronizationMode": "None",
                    "operationMode": "Server",
                    "autoExpandSelect": true,
                    "earlyRequests": true
                }
            }
        },
        "routing": {
            "routes": [
                {
                    "pattern": ":?query:",
                    "name": "StudentsList",
                    "target": "StudentsList"
                },
                {
                    "pattern": "Students({key}):?query:",
                    "name": "StudentsObjectPage",
                    "target": "StudentsObjectPage"
                },
                {
                    "pattern": "Students({key})/addresses({key2}):?query:",
                    "name": "AddressObjectPage",
                    "target": "AddressObjectPage"
                },
                {
                    "pattern": "Students({key})/enrollments({key2}):?query:",
                    "name": "EnrollmentObjectPage",
                    "target": "EnrollmentObjectPage"
                }
            ],
            "targets": {
                "StudentsList": {
                    "type": "Component",
                    "id": "StudentsList",
                    "name": "sap.fe.templates.ListReport",
                    "options": {
                        "settings": {
                            "contextPath": "/Students",
                            "variantManagement": "Page",
                            "initialLoad": "Enabled",
                            "navigation": {
                                "Students": {
                                    "detail": {
                                        "route": "StudentsObjectPage"
                                    }
                                }
                            }
                        }
                    }
                },
                "StudentsObjectPage": {
                    "type": "Component",
                    "id": "StudentsObjectPage",
                    "name": "sap.fe.templates.ObjectPage",
                    "options": {
                        "settings": {
                            "contextPath": "/Students",
                            "editableHeaderContent": false,
                            "navigation": {
                                "addresses": {
                                    "detail": {
                                        "route": "AddressObjectPage"
                                    }
                                },
                                "enrollments": {
                                    "detail": {
                                        "route": "EnrollmentObjectPage"
                                    }
                                }
                            }
                        }
                    }
                },
                "AddressObjectPage": {
                    "type": "Component",
                    "id": "AddressObjectPage",
                    "name": "sap.fe.templates.ObjectPage",
                    "options": {
                        "settings": {
                            "contextPath": "/Students/addresses",
                            "editableHeaderContent": false
                        }
                    }
                },
                "EnrollmentObjectPage": {
                    "type": "Component",
                    "id": "EnrollmentObjectPage",
                    "name": "sap.fe.templates.ObjectPage",
                    "options": {
                        "settings": {
                            "contextPath": "/Students/enrollments",
                            "editableHeaderContent": false
                        }
                    }
                }
            }
        },
        "contentDensities": {
            "compact": true,
            "cozy": true
        }
    },
    "sap.ui": {
        "technology": "UI5",
        "deviceTypes": {
            "desktop": true,
            "tablet": true,
            "phone": true
        }
    },
    "sap.fiori": {
        "registrationIds": [],
        "archeType": "transactional"
    }
}
